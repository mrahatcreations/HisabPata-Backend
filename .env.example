PORT=8000
DATABASE_URL="postgresql://user:password@host:5432/hisabpata?schema=public"
JWT_SECRET="your-strong-random-secret-here"
NODE_ENV=production
CORS_ORIGINS="https://your-frontend-domain.com"
# SEED_DEFAULT_USER="true"   # uncomment to auto-create default user on first run

# Object storage (SeaweedFS S3 / MinIO / Cloudflare R2). Leave STORAGE_S3_ENDPOINT empty to use local uploads/ folder.
# STORAGE_S3_ENDPOINT="https://your-s3-endpoint"
# For Coolify: prefer internal URL (e.g. http://seaweedfs-master-xxx:8333) to avoid proxy signature issues.
# STORAGE_S3_BUCKET="hisabpata"
# STORAGE_S3_ACCESS_KEY="your-access-key"
# STORAGE_S3_SECRET_KEY="your-secret-key"
# STORAGE_S3_REGION="us-east-1"
# STORAGE_S3_FORCE_PATH_STYLE="true"

# BanglaSpeechAPI (Bengali voice → text for AI chat & quick notes)
# Deploy BanglaSpeechAPI/ — copy VALID_API_KEYS value into ASR_API_KEY here.
# ASR_BASE_URL="https://stotext.shilpigosthi.com"
# ASR_API_KEY="your_bangla_speech_api_key"
